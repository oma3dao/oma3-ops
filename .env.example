# RPC endpoints for oma3-ops scripts
# Copy this file to .env.local and fill in your Client ID.
#
# Thirdweb RPC URL pattern: https://<chainId>.rpc.thirdweb.com/<CLIENT_ID>
# Client ID is acceptable in RPC URLs. Do NOT put Secret Key or Vault Admin Key here.
#
# Node 20+ loads this automatically via: node --env-file=.env.local
#
OMA3_OPS_RPC_URL_SEPOLIA=https://11155111.rpc.thirdweb.com/<CLIENT_ID>
OMA3_OPS_RPC_URL_MAINNET=https://1.rpc.thirdweb.com/<CLIENT_ID>
