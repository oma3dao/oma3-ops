{
  "name": "oma3-ops",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic Safe transaction generation for OMA3 lock operations",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lock-add-locks": "dist/lock-add-locks.js",
    "lock-update-locks": "dist/lock-update-locks.js",
    "lock-slash": "dist/lock-slash.js",
    "lock-slash-stake": "dist/lock-slash-stake.js",
    "lock-status": "dist/lock-status.js",
    "lock-verify-json": "dist/lock-verify-json.js",
    "hash": "dist/hash.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lock-add-locks": "node --env-file=.env.local dist/lock-add-locks.js",
    "lock-update-locks": "node --env-file=.env.local dist/lock-update-locks.js",
    "lock-slash": "node --env-file=.env.local dist/lock-slash.js",
    "lock-slash-stake": "node --env-file=.env.local dist/lock-slash-stake.js",
    "lock-status": "node --env-file=.env.local dist/lock-status.js",
    "lock-verify-json": "node --env-file=.env.local dist/lock-verify-json.js",
    "hash": "node dist/hash.js",
    "admin:test-wallet": "npx tsx src/admin-wallet/test-server-wallet.ts",
    "admin:timelock-smoke-test": "npx tsx src/admin-wallet/timelock-smoke-test.ts",
    "admin:timelock-smoke-execute": "npx tsx src/admin-wallet/timelock-smoke-execute.ts",
    "admin:propose-resolver-add-issuer": "npx tsx src/admin-wallet/propose-resolver-add-issuer.ts",
    "admin:propose-resolver-remove-issuer": "npx tsx src/admin-wallet/propose-resolver-remove-issuer.ts",
    "admin:propose-registry-set-resolver": "npx tsx src/admin-wallet/propose-registry-set-resolver.ts",
    "admin:propose-registry-set-require-attestation": "npx tsx src/admin-wallet/propose-registry-set-require-attestation.ts",
    "admin:execute-proposal": "npx tsx src/admin-wallet/execute-proposal.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ethers": "^6.15.0",
    "thirdweb": "^5.119.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
